# Imagem e ref do openclaw
OPENCLAW_IMAGE=vibestack-openclaw:latest
OPENCLAW_REF=main

# Gateway
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=

# Diretorio persistente no host (auth profiles, openclaw.json, workspace — tudo aqui).
# O ./install.sh resolve isso por SO: ~/.openclaw no Mac/Windows e /root/.openclaw
# na VPS (onde HOME=/root). So' mude se quiser um caminho custom.
OPENCLAW_DATA_DIR=/root/.openclaw

# Keyring — gerar com: openssl rand -hex 32
GOG_KEYRING_PASSWORD=

# --- Backends de modelos locais (Ollama e/ou LM Studio) --------------------
# O ./install.sh pergunta qual instalar. Estas flags sao BUILD ARGS: controlam
# o que o Dockerfile baixa (instala-se SO' o que estiver 'true'). O backend
# instalado SOBE no boot (o entrypoint detecta e inicia). Adicionar o outro
# depois exige novo `docker compose build`. (Re)start manual: `start-ollama` /
# `start-lmstudio` via `docker compose exec`.
INSTALL_OLLAMA=true
INSTALL_LMSTUDIO=false

# Ollama (instalado dentro do container openclaw-vibestack).
# Mesmo esquema do OPENCLAW_DATA_DIR: ./install.sh resolve por SO.
OLLAMA_DATA_DIR=/root/.ollama

# LM Studio — diretorio persistente dos modelos (montado em /root/.lmstudio/models).
# So' tem efeito se INSTALL_LMSTUDIO=true. ./install.sh resolve por SO.
LMSTUDIO_DATA_DIR=/root/.lmstudio

# Meta Ads — System User Token gerado no Business Manager
# (Business Settings -> System Users -> Generate Token, escopo ads_management/ads_read)
META_ACCESS_TOKEN=
# Ad account ativa para a CLI 'meta ads' (formato: act_123456789).
# Pode ficar vazio — agente descobre via list_ad_accounts.
META_AD_ACCOUNT_ID=

# Google Ads — SDK oficial (MCP google-ads). Auth OAuth2 + developer token.
# Passo a passo no README (secao "Google Ads (MCP)"). Resumo:
#  1. Developer token: Google Ads -> Tools -> API Center (conta MCC).
#  2. OAuth client 'Desktop app' no Google Cloud -> client_id + client_secret.
#  3. Refresh token: rode `docker compose exec -it openclaw-vibestack googleads auth`
#     (ele imprime o GOOGLE_ADS_REFRESH_TOKEN pra colar aqui).
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# ID da conta MCC/gerenciadora (sem hifens). So' se opera contas de clientes via MCC.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Conta operada por padrao (sem hifens, ex.: 1234567890). As tools aceitam
# customer_id p/ trocar de conta em runtime.
GOOGLE_ADS_CUSTOMER_ID=

# AtlasCloud — hub de 300+ modelos (imagem/video/LLM) via MCP server OFICIAL
# (pacote npm 'atlascloud-mcp', instalado na imagem). Auth 100% por API key:
# sem login, sem volume — a chave aqui ja' sobrevive a restart/rebuild.
# Pegue em: https://www.atlascloud.ai/console/api-keys
ATLASCLOUD_API_KEY=

# Backblaze B2 — storage canonico de seeds e derivacoes do agente Criativo.
# Endpoint S3-compatible usado pelo middleware media_editor_mcp.py via boto3.
# Como obter:
#   1. Painel B2 -> "Application Keys" -> "Add a New Application Key".
#   2. Escolha um bucket (ou "All buckets") e capabilities listAllBucketNames +
#      listBuckets + readFiles + writeFiles + deleteFiles.
#   3. Copie keyID (vai em B2_KEY_ID) e applicationKey (vai em B2_APP_KEY).
#   4. O endpoint depende da regiao do bucket — veja em "Buckets" -> detalhes
#      (formato: https://s3.<region>.backblazeb2.com, ex: us-west-002).
# Estrutura de prefixos esperada no bucket:
#   inbox/    uploads humanos pendentes (dropbox para gravacoes solicitadas)
#   seeds/    midias-base classificadas: seeds/image/, seeds/video/, seeds/audio/
#   work/     derivacoes intermediarias do pipeline (work/<slug>/...)
#   final/    midias prontas para Meta Ads (estado pre-finalize)
#   requests/ pedidos pendentes de gravacao humana (JSON)
#   meta/     sidecar de lineage (criado automaticamente)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com

# Higgsfield CLI — geracao de imagem/video e soul-id (agente Criativo).
# O CLI autentica via `higgsfield auth login` (OAuth no navegador, sem API key);
# o token fica em ~/.higgsfield. Este diretorio e' montado como volume p/ a sessao
# sobreviver a restart/rebuild (aluno loga 1x via SSH). Mesmo esquema do
# OPENCLAW_DATA_DIR: ./install.sh resolve por SO (~/.higgsfield no Mac, /root/.higgsfield na VPS).
# Login (1x):  docker exec -it openclaw-vibestack higgsfield auth login
# Conferir:    docker exec -it openclaw-vibestack higgsfield auth status
HIGGSFIELD_DATA_DIR=/root/.higgsfield

# Hermes Agent (NousResearch) — alternativa ao OpenClaw, no MESMO container.
# Roda um api_server OpenAI-compatible numa porta separada (coexiste com o OpenClaw).
# Acesso via SSH tunnel: ssh -N -L 8642:127.0.0.1:8642 root@VPS -> http://localhost:8642/v1
# As tools meta-ads/media-editor sao as mesmas do OpenClaw (mesmos middlewares).
# O provider/modelo NAO e' configurado pelo build — edite ${HERMES_DATA_DIR}/config.yaml
# ou rode `docker exec -it <cont> hermes model` depois do primeiro boot.
#
# Branch/tag/commit do repo NousResearch/hermes-agent clonado no build.
HERMES_REF=main
# Diretorio persistente do HERMES_HOME (config.yaml, .env, sessions, skills, memories).
# Mesmo esquema do OPENCLAW_DATA_DIR: ./install.sh resolve por SO (~/.hermes no Mac, /root/.hermes na VPS).
HERMES_DATA_DIR=/root/.hermes
# Porta do api_server OpenAI-compatible do Hermes (default 8642).
HERMES_API_PORT=8642
# Porta do dashboard web do Hermes (pagina de gestao/chat, default 9119).
# Acesso via SSH tunnel: ssh -N -L 9119:127.0.0.1:9119 root@VPS -> http://localhost:9119
HERMES_WEB_PORT=9119
# Chave do api_server — OBRIGATORIA pro Hermes subir na 8642 (Bearer token da API).
# Gerar com: openssl rand -hex 32
HERMES_API_SERVER_KEY=
# Autorizacao de usuario do gateway Hermes. Sem allowlist o default e' NEGAR
# (o bridge do WhatsApp recebe "not authorized" do api_server). Como o controle
# de quem fala no WhatsApp ja' e' o WA_BRIDGE_ALLOWED_NUMBERS, deixamos 'true'.
# Coloque 'false' se for plugar Telegram/Discord e quiser allowlist por plataforma.
GATEWAY_ALLOW_ALL_USERS=true
# Aprovacao de comandos do agente. Num canal headless (WhatsApp/api_server) nao ha
# quem responda o prompt de aprovacao -> o agente TRAVA ate dar timeout. 'off' = auto
# aprova tudo; 'smart' = aprova baixo risco; 'manual' = sempre pergunta (trava no canal).
HERMES_APPROVALS_MODE=off

# WhatsApp via Evolution Go (whatsmeow) — servicos separados no compose
# (evolution-go + postgres). O middleware MCP 'whatsapp' (em OpenClaw e Hermes)
# alcanca a API pelo DNS do compose (http://evolution-go:8080); por isso nao
# precisa de URL publica. Pos-`up`: ative a licenca em /manager/login e pareie
# o WhatsApp (QR) — veja a secao "WhatsApp (Evolution Go)" no README.
# Imagem do Evolution Go (Docker Hub). Fixe uma tag se quiser reprodutibilidade.
EVOLUTION_IMAGE=evoapicloud/evolution-go:latest
# Porta do Evolution Go publicada em loopback no host (Manager/QR via SSH tunnel).
EVOLUTION_PORT=8080
# GLOBAL_API_KEY do Evolution (admin: criar/listar instancia). Gerar: openssl rand -hex 16
EVOLUTION_API_KEY=
# Token da INSTANCIA de WhatsApp (usado em send/qr/status). Definido no create.
# Gerar separado da global: openssl rand -hex 16
EVOLUTION_INSTANCE_TOKEN=
# Nome da instancia de WhatsApp.
EVOLUTION_INSTANCE=vibestack
# Diretorio persistente dos dados do Evolution Go (./install.sh resolve por SO).
EVOLUTION_DATA_DIR=/root/.evolution-go
# Salvar as mensagens no banco (historico). false = nao guarda.
EVOLUTION_SAVE_MESSAGES=true
# Na criacao da instancia: ignorar grupos e status (canal 1:1 com clientes).
# Pra habilitar grupos depois, mude aqui OU no Manager do Evolution (advanced settings).
EVOLUTION_IGNORE_GROUPS=true
EVOLUTION_IGNORE_STATUS=true

# Storage S3/MinIO do Evolution Go p/ MIDIA RECEBIDA (imagem/audio inbound).
# OPCIONAL: o bridge recebe midia mesmo sem isso (vem como base64 inline no webhook,
# pois WEBHOOK_FILES=true no compose). Se LIGAR, o Evolution sobe a midia no bucket e
# manda a mediaUrl (presigned) no webhook -> payload mais enxuto + arquivo no seu S3.
# Aponta p/ Backblaze B2
# (S3-compatible) ou um MinIO seu. Pode reusar as MESMAS credenciais do B2 acima:
#   MINIO_ENDPOINT = host do endpoint S3 SEM https:// (ex.: s3.us-west-002.backblazeb2.com)
#   MINIO_ACCESS_KEY = B2_KEY_ID  | MINIO_SECRET_KEY = B2_APP_KEY
#   MINIO_REGION = regiao do bucket (ex.: us-west-002) | MINIO_USE_SSL = true
EVOLUTION_MINIO_ENABLED=false
EVOLUTION_MINIO_ENDPOINT=
EVOLUTION_MINIO_ACCESS_KEY=
EVOLUTION_MINIO_SECRET_KEY=
EVOLUTION_MINIO_BUCKET=
EVOLUTION_MINIO_USE_SSL=true
EVOLUTION_MINIO_REGION=

# Proxy da instancia WhatsApp (RECOMENDADO: Static Residential / IP fixo, ex. Webshare).
# Se preenchido, o bridge cria a instancia JA' atras do proxy. Deixe vazio p/ sem proxy.
# NAO use proxy rotativo (quebra a sessao do WhatsApp Web).
EVOLUTION_PROXY_PROTOCOL=http
EVOLUTION_PROXY_HOST=
EVOLUTION_PROXY_PORT=
EVOLUTION_PROXY_USERNAME=
EVOLUTION_PROXY_PASSWORD=

# Canal inbound do WhatsApp (bridge: webhook do Evolution -> agente -> resposta).
# Qual agente RESPONDE: 'openclaw' (orquestrador) ou 'hermes' (api_server 1-agente).
# Arquitetura completa: openclaw + diretor (ver docs/AGENCY-MULTIAGENT.md).
WA_BRIDGE_AGENT=openclaw
# id do agente OpenClaw que atende o canal (orquestrador).
WA_BRIDGE_OPENCLAW_AGENT=diretor
# O bridge escuta nesta porta (so' rede interna do compose; o evolution-go aponta
# WEBHOOK_URL=http://openclaw-vibestack:<porta>/webhook automaticamente).
WA_BRIDGE_PORT=8765
# Tarefas longas (gerar criativo, multi tool-calls) podem levar minutos. Timeout (s) que o bridge espera o agente (0 = ILIMITADO, recomendado);
# e apos quantos s avisar "processando" (WA_BRIDGE_ACK_AFTER; 0 = nao avisar).
WA_BRIDGE_UPSTREAM_TIMEOUT=0
WA_BRIDGE_ACK_AFTER=20
# Numeros (CSV, so' digitos com DDI) que podem conversar com o agente pelo WhatsApp.
# VAZIO = qualquer numero que mandar mensagem fala com o agente. Recomendado preencher
# com o(s) seu(s) numero(s). Ex: 5511999999999,5521988888888
WA_BRIDGE_ALLOWED_NUMBERS=

# Postgres do Evolution Go (bancos evogo_auth / evogo_users).
# Imagem com pgvector por precaucao (superset do postgres). Pra Postgres puro,
# troque por 'postgres:16' (e o init cria os bancos sem a extensao vector).
EVOLUTION_PG_IMAGE=pgvector/pgvector:pg16
# Senha (gerar): openssl rand -hex 16
POSTGRES_PASSWORD=
# Diretorio persistente do Postgres (./install.sh resolve por SO).
POSTGRES_DATA_DIR=/root/.evogo-pg

# Telegram — preferencia: OpenClaw nativo -> agente diretor (Passo 13).
# O bootstrap (scripts/bootstrap-agency-openclaw.sh) grava channels.telegram
# no openclaw.json e DESLIGA o poll do Hermes no mesmo bot.
# Vars (compose passa pro container; OpenClaw tambem le TELEGRAM_BOT_TOKEN):
#   TELEGRAM_BOT_TOKEN=          # @BotFather /newbot
#   TELEGRAM_ALLOWED_USERS=      # IDs numericos (@userinfobot), CSV
# Legado Hermes-only: docs/TELEGRAM-SETUP.md. Nao rode Hermes+OpenClaw no mesmo token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Placeholders da agencia (docs/AGENCY-MULTIAGENT.md) — ja' preenchidos em agency/
# no fork Mart; re-rode o bootstrap apos editar prompts.
# AGENCY_SRC=/opt/agenciamart-ia/vibestack-openclaw/agency

# --- ApiProMax (proxy OpenAI-compatible; default do Hermes/Telegram) ----------
# Docs: docs/APIPROMAX.md
# NUNCA coloque keys reais neste arquivo (so' placeholders). Secrets ficam em:
#   - VPS: /opt/.../vibestack-openclaw/.env
#   - Hermes volume: /root/.hermes/.env + custom_providers em config.yaml
#   - Mac local: ~/.vibestack-openclaw-easypanel.env (chmod 600)
# Duas keys = dois providers no Hermes (apipromax-gpt / apipromax-claude), mesma base_url.
APIPROMAX_BASE_URL=https://apipromax.online/v1
APIPROMAX_GPT_API_KEY=
APIPROMAX_CLAUDE_API_KEY=
# Modelo default sugerido (chat rapido Telegram). Confirme IDs via GET /v1/models.
APIPROMAX_DEFAULT_MODEL=gpt-5.4-mini
