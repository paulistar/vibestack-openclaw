# Imagem e ref do openclaw
OPENCLAW_IMAGE=vibestack-openclaw:latest
OPENCLAW_REF=main

# Gateway
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=

# Diretorio persistente no host (auth profiles, openclaw.json, workspace — tudo aqui).
# O ./install.sh resolve isso por SO: ~/.openclaw no Mac/Windows e /root/.openclaw
# na VPS (onde HOME=/root). So' mude se quiser um caminho custom.
OPENCLAW_DATA_DIR=/root/.openclaw

# Keyring — gerar com: openssl rand -hex 32
GOG_KEYRING_PASSWORD=

# Ollama (instalado dentro do container openclaw-vibestack).
# Mesmo esquema do OPENCLAW_DATA_DIR: ./install.sh resolve por SO.
OLLAMA_DATA_DIR=/root/.ollama

# Meta Ads — System User Token gerado no Business Manager
# (Business Settings -> System Users -> Generate Token, escopo ads_management/ads_read)
META_ACCESS_TOKEN=
# Ad account ativa para a CLI 'meta ads' (formato: act_123456789).
# Pode ficar vazio — agente descobre via list_ad_accounts.
META_AD_ACCOUNT_ID=

# Backblaze B2 — storage canonico de seeds e derivacoes do agente Criativo.
# Endpoint S3-compatible usado pelo middleware media_editor_mcp.py via boto3.
# Como obter:
#   1. Painel B2 -> "Application Keys" -> "Add a New Application Key".
#   2. Escolha um bucket (ou "All buckets") e capabilities listAllBucketNames +
#      listBuckets + readFiles + writeFiles + deleteFiles.
#   3. Copie keyID (vai em B2_KEY_ID) e applicationKey (vai em B2_APP_KEY).
#   4. O endpoint depende da regiao do bucket — veja em "Buckets" -> detalhes
#      (formato: https://s3.<region>.backblazeb2.com, ex: us-west-002).
# Estrutura de prefixos esperada no bucket:
#   inbox/    uploads humanos pendentes (dropbox para gravacoes solicitadas)
#   seeds/    midias-base classificadas: seeds/image/, seeds/video/, seeds/audio/
#   work/     derivacoes intermediarias do pipeline (work/<slug>/...)
#   final/    midias prontas para Meta Ads (estado pre-finalize)
#   requests/ pedidos pendentes de gravacao humana (JSON)
#   meta/     sidecar de lineage (criado automaticamente)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com

# Claw3D Studio (visualizador 3D dos agentes, rodando no mesmo container)
# Acesso via SSH tunnel: ssh -N -L 3000:127.0.0.1:3000 root@VPS  -> http://localhost:3000
# Login Studio: usa OPENCLAW_GATEWAY_TOKEN como STUDIO_ACCESS_TOKEN (mesmo segredo).
# Settings persistidos em ${OPENCLAW_DATA_DIR}/claw3d/settings.json (regerado a cada boot).
CLAW3D_PORT=3000
