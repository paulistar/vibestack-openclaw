{
  "server": { "port": 5070 },
  "gateway": {
    "url": "http://localhost:18789",
    "token": "${OPENCLAW_GATEWAY_TOKEN}"
  },
  "openclaw": {
    "agentsDir": "/root/.openclaw/agents"
  },
  "agents": [
    { "id": "main", "name": "Earl", "emoji": "🥧", "palette": 0, "alwaysPresent": true }
  ],
  "spawnable": ["assistant"],
  "features": {
    "fireAlarm": true,
    "breakerPanel": true,
    "hamRadio": true,
    "serverRack": true,
    "dayNightCycle": true,
    "conversationHeat": true,
    "channelBadges": true,
    "sounds": true,
    "door": true
  }
}
